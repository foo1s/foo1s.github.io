<%- partial('_partial/bg-cover') %>
<%
const rawMoviesData = (site.data && site.data.movies) ? site.data.movies : [];
const movies = Array.isArray(rawMoviesData)
    ? rawMoviesData
    : (Array.isArray(rawMoviesData.movies) ? rawMoviesData.movies : []);
const fallbackPoster = '/medias/featureimages/0.jpg';
%>

<main class="content">
    <div class="container movies-page">
        <div class="card movies-card">
            <div class="card-content">
                <div class="movies-shell">
                    <header class="movies-header">
                        <h2>foo1s's Movies</h2>
                    </header>

                    <section class="movies-section">
                        <% if (movies.length) { %>
                            <div class="movies-grid">
                                <% movies.forEach(function (movie) { %>
                                    <% const posterSrc = (movie.posterLocal || movie.coverLocal || movie.poster || movie.cover || '').trim() || fallbackPoster; %>
                                    <article class="movie-item">
                                        <% if (movie.douban) { %>
                                        <a
                                            class="movie-poster-link"
                                            href="<%= movie.douban %>"
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            aria-label="Open Douban: <%= movie.title || 'Movie' %>"
                                        >
                                        <% } else { %>
                                        <div class="movie-poster-link is-disabled">
                                        <% } %>
                                            <img
                                                class="movie-poster"
                                                src="<%= posterSrc %>"
                                                alt="<%= movie.title || 'Movie Poster' %>"
                                                loading="lazy"
                                                referrerpolicy="no-referrer"
                                                onerror="this.onerror=null;this.src='<%= fallbackPoster %>'"
                                            >
                                        <% if (movie.douban) { %>
                                        </a>
                                        <% } else { %>
                                        </div>
                                        <% } %>

                                        <div class="movie-meta">
                                            <% if (movie.review) { %>
                                            <a class="movie-title movie-title-link" href="<%= movie.review %>"><%= movie.title || 'Untitled Movie' %></a>
                                            <% } else { %>
                                            <p class="movie-title"><%= movie.title || 'Untitled Movie' %></p>
                                            <% } %>

                                            <p class="movie-detail">
                                                <%= movie.director || movie.subtitle || 'Unknown Director' %>
                                                <% if (movie.year) { %> · <%= movie.year %><% } %>
                                            </p>
                                        </div>
                                    </article>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <div class="movies-empty">
                                No movies found. Add data in <code>source/_data/movies.json</code>.
                            </div>
                        <% } %>
                    </section>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .movies-page {
        margin-top: -60px;
    }

    .movies-card {
        border-radius: 16px;
    }

    .movies-shell {
        max-width: 980px;
        margin: 0 auto;
    }

    .movies-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .movies-header h2 {
        margin: 0;
        padding-bottom: 10px;
        border-bottom: 1px solid #eee;
        color: #1f2d3d;
        font-size: 28px;
        font-weight: 600;
    }

    .movies-section {
        margin-top: 16px;
    }

    .movies-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 20px;
    }

    .movie-item {
        display: block;
        border-radius: 10px;
    }

    .movie-poster-link {
        display: block;
        border-radius: 10px;
        transition: transform 0.22s ease;
    }

    .movie-poster-link:hover {
        transform: translateY(-4px);
    }

    .movie-poster-link.is-disabled {
        cursor: default;
    }

    .movie-poster {
        width: 100%;
        aspect-ratio: 3 / 4;
        object-fit: cover;
        border-radius: 8px;
        display: block;
        box-shadow: 0 10px 24px rgba(31, 45, 61, 0.14);
    }

    .movie-meta {
        margin-top: 10px;
    }

    .movie-title {
        margin: 0;
        color: #1f2d3d;
        font-size: 15px;
        font-weight: 600;
        line-height: 1.45;
    }

    .movie-title-link {
        display: inline-block;
        text-decoration: none;
        transition: color 0.18s ease;
    }

    .movie-title-link:hover {
        color: #2d7be7;
    }

    .movie-detail {
        margin: 6px 0 0;
        color: #708092;
        font-size: 13px;
    }

    .movies-empty {
        padding: 14px 16px;
        border: 1px solid #ecf0f4;
        border-radius: 10px;
        color: #5f6f82;
        background: #fbfcfe;
        font-size: 14px;
    }

    @media (max-width: 980px) {
        .movies-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @media (max-width: 768px) {
        .movies-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }
    }

    @media (max-width: 460px) {
        .movies-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
