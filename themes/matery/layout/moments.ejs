<%- partial('_partial/bg-cover') %>
<%
const moments = (site.data && Array.isArray(site.data.moments)) ? site.data.moments : [];
const avatar = theme.profile && theme.profile.avatar ? theme.profile.avatar : '/medias/avatar.jpg';
const author = config.author || 'foo1s';
const sortedMoments = moments.slice().sort(function (a, b) {
    return new Date(b.date || 0) - new Date(a.date || 0);
});
function renderMomentMarkdown(content) {
    const text = String(content || '');
    try {
        if (typeof markdown === 'function') {
            return markdown(text);
        }
    } catch (error) {
        // Fallback below keeps old plain-text behavior if the renderer is unavailable.
    }
    return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\n/g, '<br>');
}
%>

<main class="content">
    <div class="moments-shell">
        <header class="moments-header">
            <h2>foo1s's Moments</h2>
            <p>哥们，又在胡须乱想什么呢</p>
        </header>

        <section class="moments-feed">
            <% if (sortedMoments.length) { %>
                <% sortedMoments.forEach(function (item) { %>
                <% const images = Array.isArray(item.images) ? item.images : []; %>
                <article class="moment-item">
                    <img class="moment-avatar" src="<%- theme.jsDelivr.url %><%- url_for(avatar) %>" alt="<%- author %>">
                    <div class="moment-main">
                        <div class="moment-meta">
                            <span class="moment-author"><%- author %></span>
                            <time><%= item.date ? date(item.date, 'YYYY-MM-DD HH:mm') : '' %></time>
                        </div>

                        <% if (item.content) { %>
                        <div class="moment-content"><%- renderMomentMarkdown(item.content) %></div>
                        <% } %>

                        <% if (images.length) { %>
                        <div class="moment-images moment-images-<%= images.length === 1 ? 'single' : images.length === 2 ? 'double' : 'grid' %>">
                            <% images.forEach(function (img) { %>
                            <a href="<%- url_for(img) %>" target="_blank" rel="noopener noreferrer">
                                <img src="<%- url_for(img) %>" alt="moment image">
                            </a>
                            <% }); %>
                        </div>
                        <% } %>

                        <div class="moment-actions" aria-hidden="true">
                            <span><i class="far fa-heart"></i></span>
                            <span><i class="far fa-comment-alt"></i><% if (item.comments) { %><em><%= item.comments %></em><% } %></span>
                            <span class="moment-more"><i class="fas fa-ellipsis-h"></i></span>
                        </div>
                    </div>
                </article>
                <% }); %>
            <% } else { %>
            <div class="moments-empty">
                Add your first moment in <code>source/_data/moments.json</code>.
            </div>
            <% } %>
        </section>
    </div>
</main>

<style>
    .moments-shell {
        max-width: 760px;
        margin: -60px auto 28px;
        background: rgba(255, 255, 255, 0.98);
        border: 1px solid #e9eef5;
        border-radius: 12px;
        overflow: hidden;
    }

    .moments-header {
        padding: 24px 28px 18px;
        border-bottom: 1px solid #f0f2f5;
    }

    .moments-header h2 {
        margin: 0;
        color: #1f2d3d;
        font-size: 26px;
        font-weight: 650;
        line-height: 1.25;
    }

    .moments-header p {
        margin: 8px 0 0;
        color: #8a95a5;
        font-size: 14px;
        line-height: 1.6;
    }

    .moments-feed {
        display: flex;
        flex-direction: column;
    }

    .moment-item {
        display: flex;
        gap: 14px;
        padding: 24px 28px;
        border-bottom: 1px solid #f0f2f5;
    }

    .moment-item:last-child {
        border-bottom: 0;
    }

    .moment-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        object-fit: cover;
        flex: 0 0 auto;
    }

    .moment-main {
        min-width: 0;
        flex: 1;
    }

    .moment-meta {
        display: flex;
        align-items: baseline;
        gap: 8px;
        line-height: 1.25;
    }

    .moment-author {
        color: #606976;
        font-size: 17px;
        font-weight: 700;
    }

    .moment-meta time {
        color: #9aa3af;
        font-size: 13px;
    }

    .moment-content {
        margin: 8px 0 0;
        color: #1f2933;
        font-size: 17px;
        line-height: 1.75;
        word-break: break-word;
    }

    .moment-content > :first-child {
        margin-top: 0;
    }

    .moment-content > :last-child {
        margin-bottom: 0;
    }

    .moment-content p {
        margin: 0 0 0.85em;
        font-size: inherit;
        line-height: inherit;
    }

    .moment-content ul,
    .moment-content ol {
        margin: 0.4em 0 0.85em 1.35em;
        padding-left: 0.5em;
        list-style-position: outside;
    }

    .moment-content ul {
        list-style-type: disc !important;
    }

    .moment-content ol {
        list-style-type: decimal !important;
    }

    .moment-content li {
        display: list-item;
        margin: 0.18em 0;
        line-height: 1.7;
    }

    .moment-content li::marker {
        color: #111827;
    }

    body.DarkMode .moment-content li::marker {
        color: #ffffff;
    }

    .moment-content a {
        color: #2f6fbd;
        text-decoration: none;
        border-bottom: 1px solid rgba(47, 111, 189, 0.28);
    }

    .moment-content a:hover {
        border-bottom-color: rgba(47, 111, 189, 0.65);
    }

    .moment-content blockquote {
        margin: 0.6em 0 0.9em;
        padding: 0.65em 0.9em;
        border-left: 3px solid #c9d4e2;
        border-radius: 0 8px 8px 0;
        background: #f7f9fc;
        color: #5d6b7b;
    }

    .moment-content code {
        padding: 0.12em 0.36em;
        border-radius: 5px;
        background: #f2f5f9;
        color: #3f4d5f;
        font-size: 0.92em;
    }

    .moment-content pre {
        margin: 0.65em 0 0.95em;
        padding: 0.9em 1em;
        overflow: auto;
        border-radius: 10px;
        background: #f5f7fa;
    }

    .moment-content pre code {
        padding: 0;
        background: transparent;
    }

    .moment-images {
        display: grid;
        align-items: start;
        gap: 10px;
        margin-top: 14px;
        max-width: 560px;
    }

    .moment-images-single {
        display: block;
        max-width: 520px;
    }

    .moment-images-double {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .moment-images-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .moment-images a {
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border: 1px solid #eef2f6;
        border-radius: 10px;
        background: #f5f7fa;
        box-shadow: 0 10px 28px rgba(31, 45, 61, 0.08);
    }

    .moment-images img {
        width: 100%;
        height: auto;
        display: block;
    }

    .moment-images-single img {
        max-height: 560px;
        object-fit: contain;
    }

    .moment-actions {
        display: flex;
        align-items: center;
        gap: 28px;
        margin-top: 18px;
        color: #1f2933;
        font-size: 18px;
    }

    .moment-actions span {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-width: 22px;
    }

    .moment-actions em {
        color: #1f2933;
        font-size: 14px;
        font-style: normal;
    }

    .moment-more {
        margin-left: auto;
        color: #a1a8b3;
    }

    .moments-empty {
        padding: 26px 28px;
        color: #6f7f93;
        font-size: 14px;
    }

    @media (max-width: 768px) {
        .moments-shell {
            margin-top: 0;
            border-left: 0;
            border-right: 0;
            border-radius: 0;
        }

        .moments-header,
        .moment-item {
            padding-left: 18px;
            padding-right: 18px;
        }

        .moment-content {
            font-size: 16px;
        }

        .moment-images-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 480px) {
        .moment-images,
        .moment-images-double,
        .moment-images-grid {
            grid-template-columns: minmax(0, 1fr);
        }
    }
</style>
