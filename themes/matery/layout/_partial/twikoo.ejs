<style>
    .twikoo-card {
        margin: 1.5rem auto;
    }

    .twikoo-card .card-content {
        padding: 20px;
    }

    #tcomments textarea {
        box-sizing: border-box;
        background: url("<%- url_for(theme.twikoo.background) %>") 100% 100% no-repeat;
    }

    #tcomments p {
        margin: 2px 2px 10px;
        font-size: 1.05rem;
        line-height: 1.78rem;
    }

    #tcomments blockquote p {
        text-indent: 0.2rem;
    }

    #tcomments a {
        padding: 0 2px;
        color: #4cbf30;
        font-weight: 500;
        text-decoration: none;
    }

    #tcomments img {
        max-width: 100%;
        height: auto;
        cursor: pointer;
    }

    #tcomments ol li {
        list-style-type: decimal;
    }

    #tcomments ol,
    ul {
        display: block;
        padding-left: 2em;
        word-spacing: 0.05rem;
    }

    #tcomments ul li,
    ol li {
        display: list-item;
        line-height: 1.8rem;
        font-size: 1rem;
    }

    #tcomments ul li {
        list-style-type: disc;
    }

    #tcomments ul ul li {
        list-style-type: circle;
    }

    #tcomments table,
    th,
    td {
        padding: 12px 13px;
        border: 1px solid #dfe2e5;
    }

    #tcomments table,
    th,
    td {
        border: 0;
    }

    table tr:nth-child(2n),
    thead {
        background-color: #fafafa;
    }

    #tcomments table th {
        background-color: #f2f2f2;
        min-width: 80px;
    }

    #tcomments table td {
        min-width: 80px;
    }

    #tcomments h1 {
        font-size: 1.85rem;
        font-weight: bold;
        line-height: 2.2rem;
    }

    #tcomments h2 {
        font-size: 1.65rem;
        font-weight: bold;
        line-height: 1.9rem;
    }

    #tcomments h3 {
        font-size: 1.45rem;
        font-weight: bold;
        line-height: 1.7rem;
    }

    #tcomments h4 {
        font-size: 1.25rem;
        font-weight: bold;
        line-height: 1.5rem;
    }

    #tcomments h5 {
        font-size: 1.1rem;
        font-weight: bold;
        line-height: 1.4rem;
    }

    #tcomments h6 {
        font-size: 1rem;
        line-height: 1.3rem;
    }

    #tcomments p {
        font-size: 1rem;
        line-height: 1.5rem;
    }

    #tcomments hr {
        margin: 12px 0;
        border: 0;
        border-top: 1px solid #ccc;
    }

    #tcomments blockquote {
        margin: 15px 0;
        border-left: 5px solid #42b983;
        padding: 1rem 0.8rem 0.3rem 0.8rem;
        color: #666;
        background-color: rgba(66, 185, 131, .1);
    }

    #tcomments pre {
        font-family: monospace, monospace;
        padding: 1.2em;
        margin: .5em 0;
        background: #272822;
        overflow: auto;
        border-radius: 0.3em;
        tab-size: 4;
    }

    #tcomments code {
        font-family: monospace, monospace;
        padding: 1px 3px;
        font-size: 0.92rem;
        color: #e96900;
        background-color: #f8f8f8;
        border-radius: 2px;
    }

    #tcomments pre code {
        font-family: monospace, monospace;
        padding: 0;
        color: #e8eaf6;
        background-color: #272822;
    }

    #tcomments pre[class*="language-"] {
        padding: 1.2em;
        margin: .5em 0;
    }

    #tcomments code[class*="language-"],
    pre[class*="language-"] {
        color: #e8eaf6;
    }

    #tcomments [type="checkbox"]:not(:checked),
    [type="checkbox"]:checked {
        position: inherit;
        margin-left: -1.3rem;
        margin-right: 0.4rem;
        margin-top: -1px;
        vertical-align: middle;
        left: unset;
        visibility: visible;
    }

    #tcomments b,
    strong {
        font-weight: bold;
    }

    #tcomments dfn {
        font-style: italic;
    }

    #tcomments small {
        font-size: 85%;
    }

    #tcomments cite {
        font-style: normal;
    }

    #tcomments mark {
        background-color: #fcf8e3;
        padding: .2em;
    }

    #tcomments table,
    th,
    td {
        padding: 12px 13px;
        border: 1px solid #dfe2e5;
    }

    table tr:nth-child(2n),
    thead {
        background-color: #fafafa;
    }

    #tcomments table th {
        background-color: #f2f2f2;
        min-width: 80px;
    }

    #tcomments table td {
        min-width: 80px;
    }

    #tcomments [type="checkbox"]:not(:checked),
    [type="checkbox"]:checked {
        position: inherit;
        margin-left: -1.3rem;
        margin-right: 0.4rem;
        margin-top: -1px;
        vertical-align: middle;
        left: unset;
        visibility: visible;
    }

    /* Minimal Twikoo skin: keep the comment engine, soften the visual system. */
    .twikoo-card {
        max-width: 1120px;
        margin: 2rem auto !important;
        background: rgba(255, 255, 255, 0.98) !important;
        border: 1px solid #e8edf4;
        border-radius: 18px;
        box-shadow: 0 20px 48px rgba(31, 45, 61, 0.08) !important;
        overflow: hidden;
    }

    .twikoo-card .card-content {
        padding: 26px 32px 34px !important;
    }

    .twikoo-heading {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 28px 32px 0;
        color: #1f2d3d;
        font-size: 1.45rem;
        font-weight: 700;
        line-height: 1.4;
    }

    .twikoo-heading i {
        color: #5d6b7b;
        font-size: 1.35rem;
    }

    #tcomments {
        --tk-theme-color: #5d6b7b;
        --tk-color-primary: #5d6b7b;
        color: #1f2d3d;
    }

    #tcomments a {
        color: #42556b;
    }

    #tcomments textarea,
    #tcomments .el-textarea__inner {
        min-height: 116px !important;
        background: #fbfcfe !important;
        border-color: #dfe6ef !important;
        border-radius: 12px !important;
        box-shadow: none !important;
        color: #1f2d3d !important;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    #tcomments textarea:focus,
    #tcomments .el-textarea__inner:focus {
        background: #ffffff !important;
        border-color: #b8c4d4 !important;
        box-shadow: 0 0 0 3px rgba(93, 107, 123, 0.08) !important;
    }

    #tcomments .tk-avatar,
    #tcomments .tk-avatar img {
        border-radius: 12px !important;
        box-shadow: none !important;
    }

    #tcomments .tk-meta-input {
        gap: 12px;
    }

    #tcomments .tk-meta-input .el-input-group {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: none !important;
    }

    #tcomments .tk-meta-input .el-input-group__prepend {
        border-color: #dfe6ef !important;
        background: #f6f8fb !important;
        color: #526174 !important;
        font-weight: 500;
    }

    #tcomments .tk-meta-input .el-input__inner {
        border-color: #dfe6ef !important;
        background: #fbfcfe !important;
        color: #1f2d3d !important;
        box-shadow: none !important;
    }

    #tcomments .tk-meta-input .el-input__inner:focus {
        border-color: #b8c4d4 !important;
    }

    #tcomments .tk-action-icon {
        color: #5d6b7b !important;
        transition: color 0.2s ease, transform 0.2s ease;
    }

    #tcomments .tk-action-icon:hover {
        color: #2f3b4a !important;
        transform: translateY(-1px);
    }

    #tcomments .tk-preview,
    #tcomments .tk-send {
        height: 38px;
        padding: 0 18px;
        border-radius: 10px !important;
        font-weight: 600;
        box-shadow: none !important;
    }

    #tcomments .tk-preview {
        border: 1px solid #dbe3ee !important;
        background: #ffffff !important;
        color: #42556b !important;
    }

    #tcomments .tk-send {
        border: 1px solid #5d6b7b !important;
        background: #5d6b7b !important;
        color: #ffffff !important;
    }

    #tcomments .tk-send.is-disabled,
    #tcomments .tk-send:disabled {
        border-color: #dce4ee !important;
        background: #edf2f7 !important;
        color: #a7b1bf !important;
    }

    #tcomments .tk-comments-title,
    #tcomments .tk-extras,
    #tcomments .tk-empty,
    #tcomments .tk-footer {
        color: #8a95a5 !important;
    }

    /* Notion-like comment flow: compact editor, quiet timeline, no vendor noise. */
    #tcomments .tk-submit {
        max-width: 820px;
        margin: 0 auto 34px;
    }

    #tcomments .tk-submit .tk-avatar {
        width: 42px !important;
        height: 42px !important;
        margin-right: 14px;
    }

    #tcomments .tk-meta-input {
        display: grid !important;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        margin-bottom: 10px;
    }

    #tcomments .tk-meta-input .el-input-group__prepend {
        padding: 0 14px;
        font-size: 0.94rem;
    }

    #tcomments .tk-meta-input .el-input__inner {
        height: 42px;
        font-size: 0.96rem;
    }

    #tcomments textarea,
    #tcomments .el-textarea__inner {
        min-height: 96px !important;
        padding: 14px 16px !important;
        font-size: 1rem !important;
        line-height: 1.7 !important;
    }

    #tcomments .tk-row.actions {
        margin-top: 12px;
        padding-left: 0;
    }

    #tcomments .tk-comments-container {
        max-width: 820px;
        margin: 0 auto;
    }

    #tcomments .tk-comments-title {
        margin: 4px 0 8px;
        color: #1f2d3d !important;
        font-size: 1rem !important;
        font-weight: 650;
    }

    #tcomments .tk-comment {
        padding: 22px 0 !important;
        border-top: 1px solid #edf1f6;
    }

    #tcomments .tk-comment:first-child {
        border-top: 0;
    }

    #tcomments .tk-comment .tk-avatar {
        width: 40px !important;
        height: 40px !important;
        margin-right: 14px;
    }

    #tcomments .tk-comment .tk-main {
        min-width: 0;
    }

    #tcomments .tk-nick {
        color: #4d5968 !important;
        font-size: 1rem !important;
        font-weight: 700 !important;
    }

    #tcomments .tk-time,
    #tcomments .tk-tag {
        color: #9aa3af !important;
        font-size: 0.86rem !important;
    }

    #tcomments .tk-content {
        margin-top: 8px !important;
        color: #1f2933 !important;
        font-size: 1.02rem !important;
        line-height: 1.8 !important;
    }

    #tcomments .tk-content p {
        margin: 0 0 0.55rem !important;
        font-size: inherit !important;
        line-height: inherit !important;
    }

    #tcomments .tk-replies {
        margin-top: 12px !important;
        padding-left: 18px !important;
        border-left: 2px solid #edf1f6;
    }

    #tcomments .tk-footer {
        display: none !important;
    }

    @media only screen and (max-width: 600px) {
        .twikoo-card {
            margin: 1rem auto !important;
            border-radius: 12px;
        }

        .twikoo-heading {
            padding: 22px 20px 0;
            font-size: 1.28rem;
        }

        .twikoo-card .card-content {
            padding: 20px !important;
        }

        #tcomments .tk-submit,
        #tcomments .tk-comments-container {
            max-width: 100%;
        }

        #tcomments .tk-meta-input {
            grid-template-columns: minmax(0, 1fr);
            gap: 8px;
        }
    }
</style>

<div class="card twikoo-card" data-aos="fade-up">
    <div class="comment_headling twikoo-heading">
        <i class="fas fa-comments fa-fw" aria-hidden="true"></i>
        <span>评论</span>
    </div>
    <div class="card-content">
        <div id="tcomments"></div>
    </div>
</div>

<!-- <script src="<%- theme.jsDelivr.url %><%- url_for(theme.libs.js.twikoo) %>"></script> -->
<script src="https://cdn.bootcdn.net/ajax/libs/twikoo/1.6.44/twikoo.all.min.js"></script>
<script>
    twikoo.init({
        envId: '<%- theme.twikoo.envId %>',
        el: '#tcomments',
        region: '<%- theme.twikoo.region %>',
        path: '<%- theme.twikoo.path %>'
    }).then(function () {
        var tkInputs = document.querySelector('#twikoo').getElementsByTagName('input');
        for (var tkInputsIndex = 0; tkInputsIndex < tkInputs.length; tkInputsIndex++) {
            if (tkInputs[tkInputsIndex]) {
                tkInputs[tkInputsIndex].classList.add('browser-default');
            }
        }
    });
</script>
