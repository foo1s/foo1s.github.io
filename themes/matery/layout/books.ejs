<%- partial('_partial/bg-cover') %>
<%
const rawBooksData = (site.data && site.data.books) ? site.data.books : [];
const books = Array.isArray(rawBooksData)
    ? rawBooksData
    : (Array.isArray(rawBooksData.books) ? rawBooksData.books : []);
const fallbackCover = '/medias/featureimages/0.jpg';
%>

<main class="content">
    <div class="container books-page">
        <div class="card books-card">
            <div class="card-content">
                <div class="books-shell">
                    <header class="books-header">
                        <h2>foo1s's Books</h2>
                    </header>

                    <section class="books-section">
                        <!-- <h3 class="books-section-title"></h3> -->
                        <% if (books.length) { %>
                            <div class="books-grid">
                                <% books.forEach(function (book) { %>
                                    <% const coverSrc = (book.coverLocal || book.cover || '').trim() || fallbackCover; %>
                                    <article class="book-item">
                                        <% if (book.douban) { %>
                                        <a
                                            class="book-cover-link"
                                            href="<%= book.douban %>"
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            aria-label="Open Douban: <%= book.title || 'Book' %>"
                                        >
                                        <% } else { %>
                                        <div class="book-cover-link is-disabled">
                                        <% } %>
                                            <img
                                                class="book-cover"
                                                src="<%= coverSrc %>"
                                                alt="<%= book.title || 'Book Cover' %>"
                                                loading="lazy"
                                                referrerpolicy="no-referrer"
                                                onerror="this.onerror=null;this.src='<%= fallbackCover %>'"
                                            >
                                        <% if (book.douban) { %>
                                        </a>
                                        <% } else { %>
                                        </div>
                                        <% } %>

                                        <div class="book-meta">
                                            <% if (book.review) { %>
                                            <a class="book-title book-title-link" href="<%= book.review %>"><%= book.title || 'Untitled Book' %></a>
                                            <% } else { %>
                                            <p class="book-title"><%= book.title || 'Untitled Book' %></p>
                                            <% } %>

                                            <p class="book-author"><%= book.author || 'Unknown Author' %></p>

                                        </div>
                                    </article>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <div class="books-empty">
                                No books found. Add data in <code>source/_data/books.json</code>.
                            </div>
                        <% } %>
                    </section>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .books-page {
        margin-top: -60px;
    }

    .books-card {
        border-radius: 16px;
    }

    .books-shell {
        max-width: 980px;
        margin: 0 auto;
    }

    .books-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .books-header h2 {
        margin: 0;
        padding-bottom: 10px;
        border-bottom: 1px solid #eee;
        color: #1f2d3d;
        font-size: 28px;
        font-weight: 600;
    }

    .books-section {
        margin-top: 16px;
    }

    .books-section-title {
        margin: 0 0 18px;
        color: #253547;
        font-size: 22px;
        font-weight: 700;
    }

    .books-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 20px;
    }

    .book-item {
        display: block;
        border-radius: 10px;
    }

    .book-cover-link {
        display: block;
        border-radius: 10px;
        transition: transform 0.22s ease;
    }

    .book-cover-link:hover {
        transform: translateY(-4px);
    }

    .book-cover-link.is-disabled {
        cursor: default;
    }

    .book-cover {
        width: 100%;
        aspect-ratio: 3 / 4;
        object-fit: cover;
        border-radius: 8px;
        display: block;
        box-shadow: 0 10px 24px rgba(31, 45, 61, 0.14);
    }

    .book-meta {
        margin-top: 10px;
    }

    .book-title {
        margin: 0;
        color: #1f2d3d;
        font-size: 15px;
        font-weight: 600;
        line-height: 1.45;
    }

    .book-title-link {
        display: inline-block;
        text-decoration: none;
        transition: color 0.18s ease;
    }

    .book-title-link:hover {
        color: #2d7be7;
    }

    .book-author {
        margin: 6px 0 0;
        color: #708092;
        font-size: 13px;
    }

    .books-empty {
        padding: 14px 16px;
        border: 1px solid #ecf0f4;
        border-radius: 10px;
        color: #5f6f82;
        background: #fbfcfe;
        font-size: 14px;
    }

    @media (max-width: 980px) {
        .books-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @media (max-width: 768px) {
        .books-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }
    }

    @media (max-width: 460px) {
        .books-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
