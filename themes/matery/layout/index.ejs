<% if (is_home() && page.current === 1) { %>
<script>
    document.body.classList.add('home-light-bars');
</script>
<%- partial('_partial/index-cover') %>
<% } else { %>
    <%- partial('_partial/bg-cover') %>
<% } %>
<%- partial('_partial/bg-video') %>
<main class="content">

    <% if (page.current === 1
            && ((theme.dream.enable || (theme.music.enable && !theme.music.fixed))
                    || theme.video.enable || theme.recommend.enable)) { %>
    <div id="indexCard" class="index-card">
        <div class="container ">
            <div class="card">
                <div class="card-content">
                    <% if (theme.dream.enable) { %>
                        <%- partial('_widget/dream') %>
                    <% } %>

                    <% if (theme.music.enable && !theme.music.fixed) { %>
                        <%- partial('_widget/music') %>
                        <% } %>

                    <% if (theme.video.enable && ( theme.video.url || theme.video.iframeUrl ) ) { %>
                        <%- partial('_widget/video') %>
                    <% } %>

                    <% if (theme.recommend.enable) { %>
                    <div id="recommend-sections" class="recommend">
                        <%- partial('_widget/recommend') %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
    <% }%>

    <style>
        .reading-list {
            max-width: 820px;
            margin: 0 auto;
            padding: 0 10px;
        }

        .reading-list-inner {
            background: rgba(255, 255, 255, 0.96);
            border: 1px solid #e9eef5;
            border-radius: 12px;
            padding: 6px 10px 14px;
        }

        .reading-year {
            margin: 28px 0 10px;
            color: #bcc6d6;
            font-size: 2.15rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            line-height: 1.1;
            user-select: none;
        }

        .reading-item {
            display: flex;
            align-items: baseline;
            gap: 12px;
            padding: 12px 10px;
            border-radius: 8px;
            color: #1f2d3d;
            text-decoration: none;
            transition: background-color 0.2s ease;
        }

        .reading-item:hover {
            background-color: #f5f7fa;
        }

        .reading-title {
            color: #1f2d3d;
            font-size: 1.06rem;
            font-weight: 500;
            line-height: 1.6;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            flex: 0 1 auto;
        }

        .reading-leader {
            flex: 1 1 auto;
            border-bottom: 1px dotted #c8cfda;
            transform: translateY(-4px);
            min-width: 12px;
        }

        .reading-date {
            color: #9aa4b2;
            font-size: 0.92rem;
            letter-spacing: 0.02em;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            flex: 0 0 auto;
            min-width: 90px;
            text-align: right;
        }

        @media (max-width: 768px) {
            .reading-list {
                padding: 0 6px;
            }

            .reading-year {
                font-size: 1.8rem;
            }

            .reading-item {
                gap: 8px;
                padding: 10px 8px;
            }

            .reading-title {
                font-size: 1rem;
            }

            .reading-date {
                min-width: 78px;
                font-size: 0.85rem;
            }
        }
    </style>

    <article id="articles" class="container articles reading-list">
        <div class="reading-list-inner">
            <% let lastYear = ''; %>
            <% page.posts.forEach(post => { %>
            <% if (post.hide != true)  { %>
            <% const postYear = date(post.date, 'YYYY'); %>
            <% if (postYear !== lastYear) { %>
            <div class="reading-year"><%= postYear %></div>
            <% lastYear = postYear; %>
            <% } %>
            <a class="reading-item" href="<%- url_for(post.path) %>" data-aos="fade-up">
                <span class="reading-title"><%= post.title %></span>
                <span class="reading-leader" aria-hidden="true"></span>
                <time class="reading-date"><%= date(post.date, 'YYYY-MM-DD') %></time>
            </a>
            <% } %>
            <% }); %>
        </div>
    </article>

</main>

<% if (page.total > 1) { %>
<%- partial('_partial/paging') %>
<% } %>
