<%- partial('_partial/bg-cover') %>
<%
const rawAnimesData = (site.data && site.data.animes) ? site.data.animes : [];
const animes = Array.isArray(rawAnimesData)
    ? rawAnimesData
    : (Array.isArray(rawAnimesData.animes) ? rawAnimesData.animes : []);
const fallbackPoster = '/medias/featureimages/0.jpg';
%>

<main class="content">
    <div class="container animes-page">
        <div class="card animes-card">
            <div class="card-content">
                <div class="animes-shell">
                    <header class="animes-header">
                        <h2>foo1s's Anime</h2>
                    </header>

                    <section class="animes-section">
                        <% if (animes.length) { %>
                            <div class="animes-grid">
                                <% animes.forEach(function (anime) { %>
                                    <% const posterSrc = (anime.posterLocal || anime.coverLocal || anime.poster || anime.cover || '').trim() || fallbackPoster; %>
                                    <article class="animes-item">
                                        <% if (anime.douban) { %>
                                        <a
                                            class="animes-poster-link"
                                            href="<%= anime.douban %>"
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            aria-label="Open Douban: <%= anime.title || 'Anime' %>"
                                        >
                                        <% } else { %>
                                        <div class="animes-poster-link is-disabled">
                                        <% } %>
                                            <img
                                                class="animes-poster"
                                                src="<%= posterSrc %>"
                                                alt="<%= anime.title || 'Anime Poster' %>"
                                                loading="lazy"
                                                referrerpolicy="no-referrer"
                                                onerror="this.onerror=null;this.src='<%= fallbackPoster %>'"
                                            >
                                        <% if (anime.douban) { %>
                                        </a>
                                        <% } else { %>
                                        </div>
                                        <% } %>

                                        <div class="animes-meta">
                                            <% if (anime.review) { %>
                                            <a class="animes-title animes-title-link" href="<%= anime.review %>"><%= anime.title || 'Untitled Anime' %></a>
                                            <% } else { %>
                                            <p class="animes-title"><%= anime.title || 'Untitled Anime' %></p>
                                            <% } %>

                                            <p class="animes-detail">
                                                <%= anime.subtitle || anime.director || 'Unknown Type' %>
                                                <% if (anime.year) { %> · <%= anime.year %><% } %>
                                            </p>
                                        </div>
                                    </article>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <div class="animes-empty">
                                No anime found. Add data in <code>source/_data/animes.json</code>.
                            </div>
                        <% } %>
                    </section>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .animes-page {
        margin-top: -60px;
    }

    .animes-card {
        border-radius: 16px;
    }

    .animes-shell {
        max-width: 980px;
        margin: 0 auto;
    }

    .animes-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .animes-header h2 {
        margin: 0;
        padding-bottom: 10px;
        border-bottom: 1px solid #eee;
        color: #1f2d3d;
        font-size: 28px;
        font-weight: 600;
    }

    .animes-section {
        margin-top: 16px;
    }

    .animes-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 20px;
    }

    .animes-item {
        display: block;
        border-radius: 10px;
    }

    .animes-poster-link {
        display: block;
        border-radius: 10px;
        transition: transform 0.22s ease;
    }

    .animes-poster-link:hover {
        transform: translateY(-4px);
    }

    .animes-poster-link.is-disabled {
        cursor: default;
    }

    .animes-poster {
        width: 100%;
        aspect-ratio: 3 / 4;
        object-fit: cover;
        border-radius: 8px;
        display: block;
        box-shadow: 0 10px 24px rgba(31, 45, 61, 0.14);
    }

    .animes-meta {
        margin-top: 10px;
    }

    .animes-title {
        margin: 0;
        color: #1f2d3d;
        font-size: 15px;
        font-weight: 600;
        line-height: 1.45;
    }

    .animes-title-link {
        display: inline-block;
        text-decoration: none;
        transition: color 0.18s ease;
    }

    .animes-title-link:hover {
        color: #2d7be7;
    }

    .animes-detail {
        margin: 6px 0 0;
        color: #708092;
        font-size: 13px;
    }

    .animes-empty {
        padding: 14px 16px;
        border: 1px solid #ecf0f4;
        border-radius: 10px;
        color: #5f6f82;
        background: #fbfcfe;
        font-size: 14px;
    }

    @media (max-width: 980px) {
        .animes-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @media (max-width: 768px) {
        .animes-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }
    }

    @media (max-width: 460px) {
        .animes-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
